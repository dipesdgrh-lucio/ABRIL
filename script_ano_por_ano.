--DROP TABLE #BASE
SELECT C.REGIAO,
       C.NOMEDE,
    A.CD_UNID_ADM_CLASS AS UA, --UA DE CLASSIFICAÇÃO   
    C.NOMEUA,
       B.NM_PESSOA AS NOME,
       A.NR_CPF, 
       LEFT(A.NR_RG,12) AS RG,
       A.NR_DI,          
    CASE WHEN A.CD_EVE = 10 THEN '10 - CONTRATO' ELSE A.CD_EVE END EVENTO,
    A.CD_CARGO_FUNC_ATUAL AS CARGO,
    D.NM_CARGO,
    FORMAT(A.DT_INI_EXERC,'dd/MM/yyyy') AS DTIEXER,
    CASE WHEN A.DT_INI_EXERC >= '2018-01-01'AND A.DT_INI_EXERC <= '2018-12-31' THEN '2018'
         WHEN A.DT_INI_EXERC >= '2019-01-01'AND A.DT_INI_EXERC <= '2019-12-31' THEN '2019'
         WHEN A.DT_INI_EXERC >= '2020-01-01'AND A.DT_INI_EXERC <= '2020-12-31' THEN '2020'
         WHEN A.DT_INI_EXERC >= '2021-01-01'AND A.DT_INI_EXERC <= '2021-12-31' THEN '2021'
         WHEN A.DT_INI_EXERC >= '2022-01-01'AND A.DT_INI_EXERC <= '2022-12-31' THEN '2022'
   WHEN A.DT_INI_EXERC >= '2023-01-01'AND A.DT_INI_EXERC <= '2023-12-31' THEN '2023'
   WHEN A.DT_INI_EXERC >= '2024-01-01'AND A.DT_INI_EXERC <= '2024-12-31' THEN '2024'
   WHEN A.DT_INI_EXERC >= '2025-01-01'AND A.DT_INI_EXERC <= '2025-12-31' THEN '2025'
   WHEN A.DT_INI_EXERC >= '2026-01-01'AND A.DT_INI_EXERC <= '2026-12-31' THEN '2026'
    END AS ANO,
    CASE WHEN A.ID_CAT_FUNC = 'O' THEN 'O - TEMPORARIO' ELSE A.ID_CAT_FUNC END AS CATEG,
    CASE WHEN A.CD_EVE_TRM IS NOT NULL THEN 'E - EXCLUIDO' ELSE 'ATIVO' END AS SITUACAO,
    ISNULL(A.CD_EVE_TRM,'') AS DESLIG, --CORRIGIR NO EXCEL O MOTIVO 394 PARA 290 
    ISNULL(E.EVENTO,'') AS NMDESLIG, --CORRIGIR NO EXCEL O NOME DO MOTIVO 290
    ISNULL(FORMAT(A.DT_INIC_VIGEN_EVENT_TRM,'dd/MM/yyyy'),'') AS DTDESLIG
INTO #BASE
FROM CONTAGEH.DBO.TB_ATRIB_EVENTO AS A
LEFT JOIN SAS.[032026].TB_PESSOAL AS B
     ON A.NR_CPF = B.NR_CPF 
LEFT JOIN CEPEA_SAS.DBO.ARQDEUA0326 AS C
     ON A.CD_UNID_ADM_CLASS = C.UA
LEFT JOIN CEPEA_SAS.dbo.TAB_CARGO0326 AS D
     ON A.CD_CARGO_FUNC_ATUAL = D.CD_CARGO
LEFT JOIN CEPEA_SAS.dbo.TAB_CODBFE AS E
     ON A.CD_EVE_TRM = E.COD
WHERE A.CD_TIP_EVE = 'CF'
AND A.CD_EVE = '10' --CONTRATO TEMPORÁRIO  
AND A.CD_CARGO_FUNC_ATUAL IN(6407,6408,5774)   --4341
AND A.DT_INI_EXERC >= '2018-01-01' AND A.DT_INI_EXERC <= '2020-12-31'

--TOTALIZAÇÃO P/ ANO
 SELECT ANO,
       COUNT(*) AS TTDOC
FROM #BASE
GROUP BY ANO
ORDER BY ANO
