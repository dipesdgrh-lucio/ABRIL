DROP TABLE IF EXISTS #AULAS_L
select DISTINCT
REGIAO,
NOMEDE,
MATERIA,
DEN_MATERIA,
NOMEESC,
--CPF,
SUM (TT_AULAS_LIVRES) AS TOTAL_AULAS_LIVRES
--INTO #AULAS_L
from cepea_sas.dbo.chor_SALA_AULA0326
WHERE MATERIA = '2100'
AND NOMEDE = 'MAUA'
GROUP BY 
REGIAO,
NOMEDE,
MATERIA,
DEN_MATERIA,
NOMEESC
--CPF
ORDER BY REGIAO 

