DROP TABLE IF EXISTS #ANIVERSARIANTES
SELECT  A.REGIAO,
	    B.CODUA_E,
	    A.NOMEUA,
	    B.NOME, 
	    B.RG12,
	    B.DI,
		B.IDADE,
		FORMAT(DTNASC,'dd/MM/yyyy') AS DATANASCIMENTO,                
		FORMAT(DTNASC,'MM') AS MES_NASCIMENTO
INTO #ANIVERSARIANTES
FROM CEPEA_SAS.DBO.ARQDEUA0326 AS A
    LEFT JOIN CEPEA_SAS.DBO.CTG0326 AS B
        ON A.UA = B.CODUA_E
WHERE REGIAO = 'O_CENTRAL'
      and CODUA_E = 39734         



SELECT * 
FROM #ANIVERSARIANTES
WHERE MES_NASCIMENTO in ('10') -- MÊS
ORDER BY NOME, IDADE
