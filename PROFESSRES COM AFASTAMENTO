SELECT DISTINCT 
B.REGIAO,	
B.NOMEUA AS UNIDADE_REGIONAL_ENSINO,
B.NOMEDE AS URE,
B.UA,
A.NOME AS NOME_SERVIDOR,
A.RG,
A.DI,
A.CPF,
C.NM_CARGO AS NOME_CARGO,
A.CATEG_C AS CATEGORIA,
FORMAT (A.DTIEXER_C, 'MM/dd/yyyy') AS DATA_INÍCIO_EXERCÍCIO, --atenção com as datas. 
A.MOTLICE AS MOTIVO_LICENCA, 
FORMAT (A.DTILICE, 'MM/dd/yyyy') AS DATA_INICIO_AFAST --atenção com o formato das datas.
	
FROM CEPEA_SAS.DBO.CTG0326 AS A 
LEFT JOIN cepea_sas.dbo.arqdeua0326 AS B
ON B.UA = A.CODUA_E
LEFT JOIN CEPEA_SAS.DBO.TAB_CARGO0326 AS C 
ON C.CD_CARGO = A.CARGO_E 
WHERE MOTLICE IN ('107', '237') --ART 202 E JUDICIAL.
OR MOTIAFAS IN ('107', '237')
